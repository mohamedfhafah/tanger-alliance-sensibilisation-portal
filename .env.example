# Flask Configuration
FLASK_APP=app.py
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_here

# Database Configuration
SQLALCHEMY_DATABASE_URI=sqlite:///instance/tanger_alliance.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER="Portail Sécurité Tanger Alliance <noreply@tangeralliance.com>"

# Security
# Generate a new secret key with: python -c "import secrets; print(secrets.token_hex(32))"
# For email password, use App Password for Gmail (not your regular password)
