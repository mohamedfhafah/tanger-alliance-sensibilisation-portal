<!DOCTYPE html>
<html lang="fr">
<head>
    <!-- Theme Flash prevention -->
    <script>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <script src="{{ url_for('static', filename='js/cache-override.js') }}"></script>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>{% block title %}Portail Sécurité - Tanger Alliance{% endblock %}</title>
    <link rel="icon" href="{{ url_for('static', filename='images/tanger-alliance-logo.png') }}">

    <!-- Google Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Core UI Dependencies -->
    <link rel="stylesheet" href="{{ url_for('static', filename='adminlte/plugins/fontawesome-free/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='adminlte/dist/css/adminlte.min.css') }}">
    
    <!-- Tanger Alliance Design System (The Premium Layer) -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/premium-theme.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/main.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dashboard.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/tanger-alliance-navigation.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/module-cards.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dark-mode.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/modules-common.css') }}">
    
    <!-- Legacy & Specific overrides (Kept for compatibility) -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/badges.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/quiz-system.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/quiz-system-override.css') }}">

    <style>
        /* Minimalist Global Overrides */
        body {
            font-family: 'Inter', sans-serif !important;
            -webkit-font-smoothing: antialiased;
        }
        
        /* Premium Brand Area in Sidebar */
        .tanger-nav-brand-logo { 
            background-color: white; 
            padding: 4px; 
            border-radius: var(--radius-sm);
        }
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}"> %}">
<div class="wrapper">
    <!-- TANGER ALLIANCE MODERN NAVIGATION SYSTEM -->
    <!-- Skip Navigation Link for Accessibility -->
    <a href="#main-content" class="tanger-nav-skip-link">Passer au contenu principal</a>
    
    <!-- Top Navigation Bar -->
    <nav class="tanger-nav-topbar" role="banner" aria-label="Navigation principale">
        <div class="tanger-nav-topbar-content">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <button class="tanger-nav-menu-toggle" 
                        aria-label="Ouvrir/Fermer le menu de navigation" 
                        aria-expanded="false"
                        aria-controls="main-navigation">
                    <i class="fas fa-bars" aria-hidden="true"></i>
                </button>
                <a href="{{ url_for('main.home') }}" class="tanger-nav-brand" aria-label="Accueil Tanger Alliance">
                    <img src="{{ url_for('static', filename='images/tanger-alliance-logo.png') }}" 
                         alt="Logo Tanger Alliance" class="tanger-nav-brand-logo">
                    <span class="tanger-nav-brand-text">Tanger Alliance</span>
                </a>
            </div>
            
            <div class="tanger-nav-actions">
                <form class="tanger-nav-search" action="{{ url_for('main.search') }}" method="get" role="search">
                    <label for="search-input" class="tanger-nav-sr-only">Rechercher</label>
                    <input type="search" 
                           id="search-input"
                           name="q" 
                           placeholder="Rechercher modules, simulations..." 
                           aria-label="Rechercher modules, simulations"
                           autocomplete="off">
                    <button type="submit" aria-label="Lancer la recherche">
                        <i class="fas fa-search" aria-hidden="true"></i>
                    </button>
                </form>
                
                <!-- Dark Mode Toggle Button -->
                <button class="tanger-nav-dark-mode-toggle" 
                        id="darkModeToggle"
                        aria-label="Basculer entre mode clair et mode sombre"
                        title="Basculer le mode sombre">
                    <i class="fas fa-moon" aria-hidden="true"></i>
                </button>
                
                <div class="tanger-nav-user-dropdown">
                    <div class="tanger-nav-user" 
                         role="button" 
                         tabindex="0" 
                         aria-label="Menu utilisateur {{ current_user.username if current_user.is_authenticated else 'Invité' }}"
                         aria-haspopup="true"
                         aria-expanded="false"
                         onclick="toggleUserDropdown()">
                        <img src="{{ url_for('static', filename='profile_pics/' + (current_user.profile_picture or 'default_profile.jpg')) if current_user.is_authenticated else url_for('static', filename='images/default-profile.png') }}" 
                             alt="Photo de profil de {{ current_user.username if current_user.is_authenticated else 'Invité' }}" 
                             class="tanger-nav-user-avatar">
                        <div class="tanger-nav-user-info">
                            <span class="tanger-nav-user-name">
                                {{ current_user.username if current_user.is_authenticated else 'Invité' }}
                            </span>
                            <span class="tanger-nav-user-role">
                                {{ 'Administrateur' if current_user.is_authenticated and current_user.is_admin else 'Utilisateur' }}
                            </span>
                        </div>
                        <i class="fas fa-chevron-down tanger-nav-user-dropdown-icon" aria-hidden="true"></i>
                    </div>
                    
                    <!-- User Dropdown Menu -->
                    <div class="tanger-nav-user-dropdown-menu" id="userDropdownMenu">
                        {% if current_user.is_authenticated %}
                        <a href="{{ url_for('main.profile') }}" class="tanger-nav-dropdown-item">
                            <i class="fas fa-user" aria-hidden="true"></i>
                            <span>Mon Profil</span>
                        </a>
                        <a href="{{ url_for('main.dashboard') }}" class="tanger-nav-dropdown-item">
                            <i class="fas fa-tachometer-alt" aria-hidden="true"></i>
                            <span>Tableau de bord</span>
                        </a>
                        <a href="{{ url_for('main.activity_history') }}" class="tanger-nav-dropdown-item">
                            <i class="fas fa-history" aria-hidden="true"></i>
                            <span>Historique</span>
                        </a>
                        <div class="tanger-nav-dropdown-divider"></div>
                        <a href="{{ url_for('auth.logout') }}" class="tanger-nav-dropdown-item tanger-nav-logout">
                            <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
                            <span>Se déconnecter</span>
                        </a>
                        {% else %}
                        <a href="{{ url_for('auth.login') }}" class="tanger-nav-dropdown-item">
                            <i class="fas fa-sign-in-alt" aria-hidden="true"></i>
                            <span>Se connecter</span>
                        </a>
                        <a href="{{ url_for('auth.register') }}" class="tanger-nav-dropdown-item">
                            <i class="fas fa-user-plus" aria-hidden="true"></i>
                            <span>S'inscrire</span>
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Modern Sidebar Navigation -->
    <aside class="tanger-nav-sidebar" 
           id="main-navigation"
           role="navigation" 
           aria-label="Menu principal de navigation">
        <!-- User Panel -->
        <div class="tanger-nav-user-panel">
            <img src="{{ url_for('static', filename='profile_pics/' + (current_user.profile_picture or 'default_profile.jpg')) if current_user.is_authenticated else url_for('static', filename='images/default-profile.png') }}" 
                 alt="Photo de profil" class="tanger-nav-user-panel-avatar">
            <div class="tanger-nav-user-panel-name">
                {{ current_user.username if current_user.is_authenticated else 'Invité' }}
            </div>
            <div class="tanger-nav-user-panel-role">
                {{ 'Administrateur' if current_user.is_authenticated and current_user.is_admin else 'Utilisateur' }}
            </div>
        </div>
        
        <!-- Navigation Menu -->
        <nav class="tanger-nav-menu" role="menubar">
            <!-- Navigation Section -->
            <div class="tanger-nav-menu-section" role="group" aria-labelledby="nav-section-1">
                <h6 class="tanger-nav-menu-section-title" id="nav-section-1">Navigation</h6>
                
                <div class="tanger-nav-menu-item" role="none">
                    <a href="{{ url_for('main.dashboard') }}" 
                       class="tanger-nav-menu-link" 
                       role="menuitem"
                       aria-label="Aller au tableau de bord">
                        <i class="fas fa-tachometer-alt tanger-nav-menu-icon" aria-hidden="true"></i>
                        <span class="tanger-nav-menu-text">Tableau de bord</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item" role="none">
                    <a href="{{ url_for('main.dashboard') }}?view=modules" 
                       class="tanger-nav-menu-link" 
                       role="menuitem"
                       aria-label="Accéder aux modules de formation">
                        <i class="fas fa-graduation-cap tanger-nav-menu-icon" aria-hidden="true"></i>
                        <span class="tanger-nav-menu-text">Modules de formation</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item" role="none">
                    <a href="{{ url_for('main.simulations') }}" 
                       class="tanger-nav-menu-link" 
                       role="menuitem"
                       aria-label="Accéder aux simulations de sécurité">
                        <i class="fas fa-shield-alt tanger-nav-menu-icon" aria-hidden="true"></i>
                        <span class="tanger-nav-menu-text">Simulations</span>
                    </a>
                </div>
            </div>
            
            <!-- Formation Section -->
            <div class="tanger-nav-menu-section">
                <h6 class="tanger-nav-menu-section-title">Formation</h6>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.quiz') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-question-circle tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Quiz</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('modules.certificate') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-certificate tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Certificats</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.activity_history') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-history tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Historique</span>
                    </a>
                </div>
            </div>
            
            <!-- Outils Section -->
            <div class="tanger-nav-menu-section">
                <h6 class="tanger-nav-menu-section-title">Outils</h6>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.profile') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-user tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Profil</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.leaderboard') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-trophy tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Classement</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.search') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-search tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Recherche</span>
                    </a>
                </div>
            </div>
            
            <!-- Sécurité Section (Expandable) -->
            <div class="tanger-nav-menu-section">
                <h6 class="tanger-nav-menu-section-title">Sécurité</h6>
                
                <div class="tanger-nav-menu-item tanger-nav-menu-expandable" data-menu-id="security">
                    <a href="#" class="tanger-nav-menu-link">
                        <i class="fas fa-shield-virus tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Outils de sécurité</span>
                        <i class="fas fa-chevron-right tanger-nav-menu-expand-icon"></i>
                    </a>
                    <div class="tanger-nav-submenu">
                        <a href="{{ url_for('security.alerts') }}" class="tanger-nav-submenu-link">
                            <i class="fas fa-exclamation-triangle tanger-nav-submenu-icon"></i>
                            Alertes sécurité
                        </a>
                        <a href="{{ url_for('security.report_incident') }}" class="tanger-nav-submenu-link">
                            <i class="fas fa-bug tanger-nav-submenu-icon"></i>
                            Signalement incidents
                        </a>
                        <a href="{{ url_for('security.resources') }}" class="tanger-nav-submenu-link">
                            <i class="fas fa-book tanger-nav-submenu-icon"></i>
                            Ressources sécurité
                        </a>
                        <a href="{{ url_for('security.policy') }}" class="tanger-nav-submenu-link">
                            <i class="fas fa-file-contract tanger-nav-submenu-icon"></i>
                            Politiques
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Communauté Section -->
            <div class="tanger-nav-menu-section">
                <h6 class="tanger-nav-menu-section-title">Communauté</h6>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.about') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-info-circle tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">À propos</span>
                    </a>
                </div>
            </div>
            
            <!-- Administration Section (Admin Only) -->
            {% if current_user.is_authenticated and current_user.is_admin %}
            <div class="tanger-nav-menu-section">
                <h6 class="tanger-nav-menu-section-title">Administration</h6>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('admin_portal.index') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-cogs tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Portail Admin</span>
                        <span class="tanger-nav-menu-badge">Admin</span>
                    </a>
                </div>
            </div>
            {% endif %}
            
            <!-- Account Section -->
            {% if current_user.is_authenticated %}
            <div class="tanger-nav-menu-section tanger-nav-account-section">
                <h6 class="tanger-nav-menu-section-title">Compte</h6>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('main.profile') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-user-edit tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Paramètres</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('auth.logout') }}" class="tanger-nav-menu-link tanger-nav-logout-link">
                        <i class="fas fa-sign-out-alt tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Se déconnecter</span>
                    </a>
                </div>
            </div>
            {% else %}
            <div class="tanger-nav-menu-section tanger-nav-account-section">
                <h6 class="tanger-nav-menu-section-title">Connexion</h6>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('auth.login') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-sign-in-alt tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">Se connecter</span>
                    </a>
                </div>
                
                <div class="tanger-nav-menu-item">
                    <a href="{{ url_for('auth.register') }}" class="tanger-nav-menu-link">
                        <i class="fas fa-user-plus tanger-nav-menu-icon"></i>
                        <span class="tanger-nav-menu-text">S'inscrire</span>
                    </a>
                </div>
            </div>
            {% endif %}
        </nav>
    </aside>
    
    <!-- Mobile Overlay -->
    <div class="tanger-nav-overlay"></div>

    <!-- Main Content Area -->
    <main class="tanger-nav-main-content">
        {% block content_header %}
        <div class="content-header p-0 mb-4">
            <div class="container-fluid">
                <div class="d-flex align-items-baseline justify-content-between">
                    <div>
                        <h1 class="page-title mb-0">{% block page_title %}{{ title|default('Page') }}{% endblock %}</h1>
                    </div>
                </div>
            </div>
        </div>
        {% endblock %}

        <!-- Main content -->
        <section class="content">
            <div class="container-fluid">
                {% with messages = get_flashed_messages(with_categories=true) %}
                    {% if messages %}
                        {% for category, message in messages %}
                            <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        {% endfor %}
                    {% endif %}
                {% endwith %}

                {% block content %}{% endblock %}
            </div><!-- /.container-fluid -->
        </section>
        <!-- /.content -->
        
        <!-- Modern Footer -->
        <footer class="main-footer border-0 bg-transparent text-center py-5">
            <div class="text-muted smaller" style="font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase;">
                &copy; {{ now.year }} Tanger Alliance Safety Portal &bull; Advanced Security Training
            </div>
        </footer>
    </main>
    <!-- /.tanger-nav-main-content -->
</div>
<!-- ./wrapper -->

<!-- REQUIRED SCRIPTS -->
<!-- jQuery -->
<script src="{{ url_for('static', filename='adminlte/plugins/jquery/jquery.min.js') }}"></script>
<!-- Bootstrap 4 --> <!-- AdminLTE 3.2 uses Bootstrap 4 components -->
<script src="{{ url_for('static', filename='adminlte/plugins/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<!-- Sweet Alert 2 - Pour notifications élégantes -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- AdminLTE App -->
<script src="{{ url_for('static', filename='adminlte/dist/js/adminlte.min.js') }}"></script>
<!-- Custom JS -->
<script src="{{ url_for('static', filename='js/main.js') }}"></script>
<!-- Dark Mode JS -->
<script src="{{ url_for('static', filename='js/dark-mode.js') }}"></script>
<!-- Page Monitor JS -->
<script src="{{ url_for('static', filename='js/page-monitor.js') }}"></script>
<!-- NEW TANGER ALLIANCE JAVASCRIPT WILL BE LINKED HERE -->
<script src="{{ url_for('static', filename='js/tanger-alliance-navigation.js') }}"></script>
<!-- Modules Common JS -->
<script src="{{ url_for('static', filename='js/modules-common.js') }}"></script>
<!-- Dashboard Enhanced JS - Modern interactions and animations -->
<script src="{{ url_for('static', filename='js/dashboard-enhanced.js') }}"></script>
<!-- Dashboard Charts JS - Enhanced Chart.js with Tanger Alliance styling -->
<script src="{{ url_for('static', filename='js/dashboard-charts.js') }}"></script>

{% block scripts %}{% endblock %}
</body>
</html>