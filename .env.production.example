
# Production Environment Configuration for Tanger Alliance Security Portal

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secure-secret-key-here
DEBUG=False

# Database Configuration
DATABASE_URL=sqlite:///production_tanger_alliance.db
# For PostgreSQL: postgresql://user:password@localhost/tanger_alliance_prod

# Security Configuration
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=None

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB max file size
UPLOAD_FOLDER=uploads/

# Email Configuration (if using email features)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@company.com
MAIL_PASSWORD=your-app-password

# Cache Configuration
CACHE_TYPE=simple
# For Redis: CACHE_TYPE=redis, CACHE_REDIS_URL=redis://localhost:6379

# Session Configuration
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Performance Configuration
SEND_FILE_MAX_AGE_DEFAULT=31536000  # 1 year cache for static files
